# Copy this file to .env and fill in your values:
#   cp .env.example .env

# HuggingFace token — required for pyannote speaker diarization
# Get yours at https://huggingface.co/settings/tokens
# Also accept terms at https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=hf_your_token_here

# Ollama model to use for extraction + gatekeeper
# Run 'ollama list' to see what's available on your Pi
SERENDIPITY_DEFAULT_MODEL=qwen2.5:3b

# Whisper device — keep as 'cpu' on Pi5 (no CUDA)
SERENDIPITY_WHISPER_DEVICE=cpu

# Whisper model size — 'base' or 'small' recommended for Pi5 speed
SERENDIPITY_WHISPER_MODEL=base

# Ollama host — change if Ollama runs on another machine on your LAN
OLLAMA_HOST=http://localhost:11434
